# Backend only. Never expose this key to the extension or commit a real value.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_ENABLE_THINKING_FOR_ANSWERS=false
PORT=8787
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,moz-extension://YOUR_EXTENSION_ID
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RUN_DEEPSEEK_INTEGRATION_TESTS=false
