{
  "name": "penbot",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "extension",
    "server"
  ],
  "scripts": {
    "build": "npm run build -w server && npm run build -w extension",
    "dev:extension": "npm run dev -w extension",
    "dev:server": "npm run dev -w server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w extension",
    "test": "vitest run",
    "test:integration": "vitest run server/test/app.test.ts extension/src/content/selection/selection.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.15",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
